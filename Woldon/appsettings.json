{
  // ==========================================
  // LOGGING CONFIGURATION
  // Defines the verbosity of application logs
  // ==========================================
  "Logging": {
    "LogLevel": {
      "Default": "Information", // Standard application events
      "Microsoft.AspNetCore": "Warning", // Suppress noisy framework logs, show only warnings/errors
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning" // Log SQL queries only if they fail
    }
  },

  // ==========================================
  // SECURITY & HOSTING
  // ==========================================

  // AllowedHosts: "*" allows the app to respond to any domain/IP (standard for Homelabs)
  "AllowedHosts": "*",

  // ==========================================
  // DATABASE CONNECTION STRINGS
  // ==========================================
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=woldon.db"
  },

  // ==========================================
  // APPLICATION CUSTOM SETTINGS
  // (Reserved for future global parameters like 
  //  default broadcast address or WOL ports)
  // ==========================================
  "WoldonSettings": {
    "Version": "1.0.0",
    "Environment": "Production"
  }
}