<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Woldon - Dashboard</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    
    <style>
        body { background-color: #0f172a; }
        .modal { transition: opacity 0.25s ease; }
        .modal-active { overflow: hidden; }
        /* Smooth color transitions for status indicators */
        .status-dot { transition: background-color 0.5s ease; }
    </style>
</head>

<body class="text-slate-200 font-sans">

    <header class="p-8 text-center relative">
        <h1 class="text-5xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500 mb-2">WOLDON</h1>
        <p class="text-slate-400 font-light tracking-widest uppercase text-sm">Your Machine Wake-up Hub</p>

        <button onclick="openAddModal()" class="absolute top-8 right-8 p-2 bg-slate-800 hover:bg-slate-700 rounded-full border border-slate-700 transition-all shadow-lg group">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-cyan-400 group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
            </svg>
        </button>
    </header>

    <main id="devicesGrid" class="max-w-6xl mx-auto p-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        </main>

    <div id="deviceModal" class="modal opacity-0 pointer-events-none fixed w-full h-full top-0 left-0 flex items-center justify-center z-50">
        <div class="modal-overlay absolute w-full h-full bg-black opacity-60" onclick="toggleModal('deviceModal')"></div>
        
        <div class="modal-container bg-slate-800 w-11/12 md:max-w-md mx-auto rounded-xl shadow-2xl z-50 overflow-y-auto border border-slate-700">
            <div class="p-6">
                <h2 id="modalTitle" class="text-xl font-bold text-cyan-400 mb-6">Device Configuration</h2>
                
                <form id="deviceForm" class="space-y-4">
                    <input type="hidden" id="devId">

                    <div>
                        <label class="block text-xs text-slate-500 uppercase font-semibold mb-1 ml-1">Device Name</label>
                        <input type="text" id="devName" placeholder="e.g. Proxmox Node" class="w-full p-3 bg-slate-900 border border-slate-700 rounded-lg focus:outline-none focus:border-cyan-500 text-sm" required>
                    </div>

                    <div>
                        <label class="block text-xs text-slate-500 uppercase font-semibold mb-1 ml-1">MAC Address</label>
                        <input type="text" id="devMac" placeholder="AA:BB:CC:DD:EE:FF" class="w-full p-3 bg-slate-900 border border-slate-700 rounded-lg focus:outline-none focus:border-cyan-500 text-sm font-mono" required>
                    </div>

                    <div>
                        <label class="block text-xs text-slate-500 uppercase font-semibold mb-1 ml-1">IP Address (Monitoring)</label>
                        <input type="text" id="devIp" placeholder="192.168.1.100" class="w-full p-3 bg-slate-900 border border-slate-700 rounded-lg focus:outline-none focus:border-cyan-500 text-sm font-mono" required>
                    </div>

                    <div class="flex gap-3 pt-4">
                        <button type="button" onclick="toggleModal('deviceModal')" class="flex-1 p-3 bg-slate-700 hover:bg-slate-600 rounded-lg transition-colors font-semibold text-sm">Cancel</button>
                        <button type="submit" class="flex-1 p-3 bg-cyan-600 hover:bg-cyan-500 rounded-lg font-bold transition-all shadow-lg text-sm">Save Device</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        // --- UI & MODAL MANAGEMENT ---

        function toggleModal(id) {
            const modal = document.getElementById(id);
            modal.classList.toggle('opacity-0');
            modal.classList.toggle('pointer-events-none');
        }

        function openAddModal() {
            document.getElementById('deviceForm').reset();
            document.getElementById('devId').value = "";
            document.getElementById('modalTitle').innerText = "Add New Device";
            toggleModal('deviceModal');
        }

        function openEditModal(id, name, mac, ip) {
            document.getElementById('devId').value = id;
            document.getElementById('devName').value = name;
            document.getElementById('devMac').value = mac;
            document.getElementById('devIp').value = ip;
            document.getElementById('modalTitle').innerText = "Edit Device Settings";
            toggleModal('deviceModal');
        }

        // --- CRUD OPERATIONS (API CALLS) ---

        /**
         * READ: Fetches all devices and renders the grid cards
         */
        async function fetchDevices() {
            try {
                const res = await fetch('/api/wake/devices');
                const devices = await res.json();
                const grid = document.getElementById('devicesGrid');

                if (devices.length === 0) {
                    grid.innerHTML = `
                        <div class="col-span-full text-center py-20">
                            <p class="text-slate-500 italic mb-2">No devices found.</p>
                            <p class="text-slate-600 text-xs">Click the + icon in the top-right to register your first machine.</p>
                        </div>`;
                    return;
                }

                grid.innerHTML = devices.map(d => `
                    <div class="bg-slate-800/50 p-6 rounded-2xl border border-slate-700 hover:border-cyan-500/50 transition-all shadow-xl group relative">
                        <div class="absolute top-4 right-4 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                            <button onclick="openEditModal(${d.id}, '${d.name}', '${d.macAddress}', '${d.ipAddress}')" class="p-1.5 bg-slate-700 hover:bg-cyan-600 rounded-md transition-colors" title="Edit">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                                </svg>
                            </button>
                            <button onclick="deleteDevice(${d.id})" class="p-1.5 bg-slate-700 hover:bg-red-600 rounded-md transition-colors" title="Delete">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                </svg>
                            </button>
                        </div>

                        <div class="flex items-center justify-between mb-4">
                            <div class="p-3 bg-slate-900 rounded-lg text-cyan-400">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                                </svg>
                            </div>
                            <div id="status-${d.id}" class="status-dot h-3 w-3 rounded-full bg-slate-600 shadow-[0_0_8px_rgba(0,0,0,0.5)]" title="Status: Unknown"></div>
                        </div>

                        <h3 class="text-xl font-bold mb-1 truncate">${d.name}</h3>
                        <p class="text-xs text-slate-500 font-mono mb-2 tracking-tight">${d.macAddress}</p>
                        <p class="device-ip text-[10px] text-slate-600 font-mono mb-4 uppercase tracking-tighter">IP: ${d.ipAddress}</p>

                        <button onclick="askForPin('${d.macAddress}')" class="w-full py-3 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-xl transition-all shadow-lg active:scale-[0.97] uppercase text-xs tracking-widest">
                            Wake Up Machine
                        </button>
                    </div>
                `).join('');

                updateStatuses();
            } catch (err) {
                console.error("Critical: Failed to fetch devices", err);
            }
        }

        /**
         * CREATE / UPDATE: Handles form submission for adding or updating devices
         */
        document.getElementById('deviceForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const id = document.getElementById('devId').value;
            const device = {
                name: document.getElementById('devName').value,
                macAddress: document.getElementById('devMac').value,
                ipAddress: document.getElementById('devIp').value
            };

            let url = id ? '/api/wake/update' : '/api/wake/add';
            let method = id ? 'PUT' : 'POST';

            if (id) device.id = parseInt(id);

            const res = await fetch(url, {
                method: method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(device)
            });

            if (res.ok) {
                toggleModal('deviceModal');
                fetchDevices();
            } else {
                alert("Operation failed. Check backend logs.");
            }
        });

        /**
         * DELETE: Removes device after confirmation
         */
        async function deleteDevice(id) {
            if (!confirm("Are you sure you want to delete this device?")) return;
            const res = await fetch('/api/wake/delete/' + id, { method: 'DELETE' });
            if (res.ok) fetchDevices();
        }

        // --- CORE ACTIONS ---

        /**
         * WAKE: Validates PIN and triggers Magic Packet broadcast
         */
        async function askForPin(mac) {
            const pin = prompt("Security Check: Enter 4-digit PIN");
            if (pin === "1234") {
                const res = await fetch('/api/wake/run/' + mac, { method: 'POST' });
                if (res.ok) alert("Magic Packet broadcasted successfully.");
            } else {
                alert("Access Denied: Invalid PIN.");
            }
        }

        // --- REAL-TIME MONITORING ---

        /**
         * PING SERVICE: Iterates through cards and updates status dots based on IP availability
         */
        async function updateStatuses() {
            const statusDots = document.querySelectorAll('[id^="status-"]');

            for (const dot of statusDots) {
                const card = dot.closest('.group');
                const ipElement = card.querySelector('.device-ip');

                if (!ipElement) continue;

                const ipText = ipElement.innerText.replace('IP: ', '').trim();

                try {
                    const res = await fetch('/api/wake/status/' + ipText);
                    if (!res.ok) throw new Error("Status check failed");

                    const data = await res.json();

                    dot.classList.remove('bg-slate-600', 'bg-green-500', 'bg-red-500');
                    if (data.online) {
                        dot.classList.add('bg-green-500', 'shadow-[0_0_10px_#22c55e]');
                        dot.title = "Status: Online";
                    } else {
                        dot.classList.add('bg-red-500');
                        dot.title = "Status: Offline";
                    }
                } catch (err) {
                    console.error("Monitor Error [" + ipText + "]:", err);
                    dot.classList.add('bg-slate-600');
                }
            }
        }

        // --- SYSTEM INITIALIZATION ---

        // Initial Data Load
        fetchDevices();
        
        // Status Polling Interval (10 seconds)
        setInterval(updateStatuses, 10000);

    </script>
</body>
</html>