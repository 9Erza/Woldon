{
  "$schema": "https://json.schemastore.org/launchsettings.json",
  "profiles": {
    // ==========================================
    // LOCAL HOSTING (Kestrel / Project Mode)
    // Runs the application directly on the OS
    // ==========================================
    "Woldon.Local": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": true,
      "launchUrl": "login.html",
      "applicationUrl": "http://localhost:5004",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },

    // ==========================================
    // CONTAINER ENGINE (Docker Mode)
    // Runs the application inside a Linux container
    // ==========================================
    "Woldon.Docker": {
      "commandName": "Docker",
      "launchBrowser": true,
      "launchUrl": "{Scheme}://{ServiceHost}:{ServicePort}/login.html",
      "publishAllPorts": true,
      "useSSL": false,
      // ------------------------------------------
      // DOCKER RUN ARGUMENTS:
      // --cap-add=NET_RAW: Required for ICMP (Ping)
      // ------------------------------------------
      "dockerfileRunArguments": "--cap-add=NET_RAW",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_HTTP_PORTS": "8080"
      }
    }
  }
}